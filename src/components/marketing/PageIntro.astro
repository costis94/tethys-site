---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="container-page section-sm">
  <div class="mx-auto max-w-4xl text-center" data-anim>
    {eyebrow && <span class="kicker">{eyebrow}</span>}
    <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">{title}</h1>
    <p class="mx-auto mt-5 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">{description}</p>
  </div>
</section>