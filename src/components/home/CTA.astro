---
import SectionIntro from "./ui/SectionIntro.astro";
---

<section class="section section-border">
  <div class="container-page">
    <div class="card-soft px-6 py-10 sm:px-10 sm:py-12" data-anim>
      <SectionIntro
        kicker="Επόμενο βήμα"
        title="Να σου δείξουμε το Tethys με τα δικά σας πραγματικά σενάρια;"
        description="Κάνουμε σύντομο walkthrough στη ροή σας και δείχνουμε πώς η πλατφόρμα μειώνει θόρυβο, λάθη και καθυστερήσεις."
        center={true}
      />

      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/el/contact" class="btn-cta">Κλείστε παρουσίαση</a>
        <a href="/el/product" class="btn-ghosty">Δείτε το προϊόν</a>
      </div>
    </div>
  </div>
</section>