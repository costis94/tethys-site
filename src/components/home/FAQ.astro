---
import SectionIntro from "./ui/SectionIntro.astro";

const faqs = [
  {
    q: "Χρειάζεται σύνδεση internet για να δουλέψει η Android εφαρμογή;",
    a: "Όχι. Η εφαρμογή λειτουργεί πλήρως εκτός σύνδεσης — ο χάρτης, οι καταγραφές αρδεύσεων και οι αναφορές πεδίου είναι διαθέσιμα ακόμα και σε περιοχές χωρίς δίκτυο. Τα δεδομένα συγχρονίζονται αυτόματα στο background μόλις αποκατασταθεί σύνδεση.",
  },
  {
    q: "Πόσο εύκολη είναι η χρήση για τους υδρονόμους;",
    a: "Η εφαρμογή σχεδιάστηκε για χρήση στο πεδίο, σε πραγματικές συνθήκες εργασίας. Η καταγραφή ποτίσματος γίνεται σε λίγα δευτερόλεπτα, με επιλογή απευθείας από τον χάρτη. Παρέχουμε εκπαίδευση και υποστήριξη κατά την εγκατάσταση.",
  },
  {
    q: "Πώς φτάνουν τα δεδομένα από το πεδίο στο Web;",
    a: "Αυτόματα. Το WorkManager της Android εφαρμογής εξασφαλίζει ότι κάθε καταγραφή και αναφορά ανεβαίνει στο σύστημα μόλις υπάρχει σύνδεση — χωρίς καμία χειροκίνητη παρέμβαση. Η διοίκηση βλέπει τα δεδομένα άμεσα στο Web περιβάλλον.",
  },
  {
    q: "Ποιους ρόλους χρηστών υποστηρίζει το σύστημα;",
    a: "Το Tethys υποστηρίζει 6 ρόλους: Υδρονόμος, Χρήστης, Διαχειριστής ΤΟΕΒ, Λογιστής, Εισαγωγή Δεδομένων και Super Admin. Κάθε ρόλος έχει συγκεκριμένα δικαιώματα πρόσβασης, εξασφαλίζοντας ότι ο καθένας βλέπει μόνο ό,τι χρειάζεται.",
  },
  {
    q: "Μπορούμε να εισάγουμε τα υπάρχοντα δεδομένα μας;",
    a: "Ναι. Το σύστημα υποστηρίζει εισαγωγή μελών και αγροτεμαχίων από CSV. Η διαδικασία γίνεται ασύγχρονα με tracking της προόδου, ώστε να μην επηρεάζεται η λειτουργία κατά τη μεταφορά δεδομένων.",
  },
  {
    q: "Τι γίνεται αν η αντλία χαλάσει ή υπάρξει συμβάν στο πεδίο;",
    a: "Ο υδρονόμος καταγράφει αμέσως αναφορά μέσω της Android εφαρμογής — με κατηγορία (συμβάν, παράβαση, ενημέρωση), GPS θέση και φωτογραφίες. Η αναφορά εμφανίζεται αυτόματα στο Web, όπου η διοίκηση μπορεί να τη διαχειριστεί και να δημιουργήσει σχετική υπόθεση.",
  },
];
---

<section class="section section-border">
  <div class="container-page">
    <SectionIntro
      kicker="Συχνές Ερωτήσεις"
      title="Έχετε απορίες; Έχουμε απαντήσεις."
      description="Αν δεν βρείτε αυτό που ψάχνετε, επικοινωνήστε μαζί μας απευθείας."
    />

    <div class="mt-10 mx-auto max-w-3xl" id="faq-list">
      {faqs.map((faq, i) => (
        <div class="faq-item" data-faq>
          <button class="faq-trigger" aria-expanded="false">
            <span>{faq.q}</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          <div class="faq-body">
            <div class="faq-body-inner">
              <p>{faq.a}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-item {
    border-bottom: 1px solid var(--tethys-line);
  }

  .faq-item:first-child {
    border-top: 1px solid var(--tethys-line);
  }

  .faq-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-size: 0.95rem;
    font-weight: 600;
    color: #0d1b2a;
    transition: color 0.2s;
  }

  .faq-trigger:hover {
    color: #00366b;
  }

  .faq-icon {
    flex-shrink: 0;
    color: #94a3b8;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), color 0.2s;
  }

  .faq-item.is-open .faq-icon {
    transform: rotate(180deg);
    color: #00366b;
  }

  /* Smooth height με grid trick */
  .faq-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item.is-open .faq-body {
    grid-template-rows: 1fr;
  }

  .faq-body-inner {
    overflow: hidden;
  }

  .faq-body-inner p {
    padding-bottom: 1.25rem;
    font-size: 0.88rem;
    line-height: 1.75;
    color: #516276;
  }
</style>

<script is:inline>
  (function () {
    var items = document.querySelectorAll("[data-faq]");
    items.forEach(function (item) {
      var trigger = item.querySelector(".faq-trigger");
      trigger.addEventListener("click", function () {
        var isOpen = item.classList.contains("is-open");
        // Κλείνει όλα
        items.forEach(function (i) {
          i.classList.remove("is-open");
          i.querySelector(".faq-trigger").setAttribute("aria-expanded", "false");
        });
        // Ανοίγει αυτό (αν δεν ήταν ήδη ανοιχτό)
        if (!isOpen) {
          item.classList.add("is-open");
          trigger.setAttribute("aria-expanded", "true");
        }
      });
    });
  })();
</script>
