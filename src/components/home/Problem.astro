---
import SectionIntro from "./ui/SectionIntro.astro";

const items = [
  {
    title: "Διάσπαρτα δεδομένα",
    body: "Καταγραφές σε χαρτί, υπολογιστικά φύλλα και τηλεφωνήματα — χωρίς ενιαία βάση.",
  },
  {
    title: "Αδιαφανής οικονομική εικόνα",
    body: "Χρεώσεις, εισπράξεις και οφειλές δύσκολα παρακολουθούνται σε πραγματικό χρόνο.",
  },
  {
    title: "Αργή επιχειρησιακή εικόνα",
    body: "Ό,τι συμβαίνει στο πεδίο φτάνει στη διοίκηση με καθυστέρηση — αν φτάσει.",
  },
];
---

<section class="section section-border">
  <div class="container-page">
    <SectionIntro
      kicker="Το πρόβλημα"
      title="Η λειτουργία ενός ΤΟΕΒ δεν πρέπει να εξαρτάται από χαρτιά και τηλεφωνήματα."
      description="Το Tethys ενοποιεί πεδίο, διοίκηση και οικονομικά σε μία κοινή ψηφιακή βάση — από την καταγραφή ποτίσματος μέχρι την είσπραξη οφειλής."
    />

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {items.map((item, i) => (
        <article class="card-soft p-5" data-anim data-anim-delay={String(0.05 * (i + 1))}>
          <span class="badge-soft">0{i + 1}</span>
          <h3 class="mt-3 text-lg font-semibold text-slate-900">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>