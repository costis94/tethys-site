---
import SectionIntro from "./ui/SectionIntro.astro";

// Βασικά προβλήματα που αντιμετωπίζει ένας ΤΟΕΒ χωρίς unified σύστημα
const items = [
  {
    title: "Διάσπαρτα δεδομένα",
    body: "Η πληροφορία μένει σε πολλά σημεία και χάνονται κρίσιμα συμφραζόμενα.",
  },
  {
    title: "Ασάφεια ευθύνης",
    body: "Δεν είναι πάντα σαφές ποιος κατέγραψε κάτι και πότε.",
  },
  {
    title: "Αργή επιχειρησιακή εικόνα",
    body: "Οι αποφάσεις βασίζονται σε δεδομένα που έρχονται με καθυστέρηση.",
  },
];
---

<section class="section section-border">
  <div class="container-page">
    <SectionIntro
      kicker="Το πρόβλημα"
      title="Η καθημερινή λειτουργία δεν πρέπει να εξαρτάται από χαρτιά και τηλεφωνήματα."
      description="Το Tethys μετατρέπει την αποσπασματική πληροφορία σε ενιαία επιχειρησιακή ροή, από το πεδίο μέχρι τη διοίκηση."
    />

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {items.map((item, i) => (
        <article class="card-soft p-5" data-anim data-anim-delay={String(0.05 * (i + 1))}>
          <span class="badge-soft">0{i + 1}</span>
          <h3 class="mt-3 text-lg font-semibold text-slate-900">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>