---
import SectionIntro from "./ui/SectionIntro.astro";

// Βήματα λειτουργίας mobile app στο πεδίο
const flow = [
  "Εντοπισμός αγροτεμαχίου στον χάρτη",
  "Γρήγορη καταγραφή ποτίσματος ή συμβάντος",
  "Αποθήκευση offline με ασφάλεια",
  "Sync στο Web μόλις αποκατασταθεί σύνδεση",
];
---

<section class="section section-border">
  <div class="container-page">
    <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
      <div>
        <SectionIntro
          kicker="Android στο πεδίο"
          title="Σχεδιασμένο για πραγματική εργασία, όχι για demo περιβάλλον."
          description="Η εμπειρία χρήσης παραμένει απλή και σταθερή σε δύσκολες συνθήκες δικτύου."
        />

        <ul class="mt-6 space-y-3">
          {flow.map((step, i) => (
            <li class="panel flex gap-3 px-4 py-3 text-sm leading-6 text-slate-700" data-anim data-anim-delay={String(0.04 * (i + 1))}>
              <span class="badge-soft shrink-0">{i + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ul>
      </div>

      <article class="card-soft p-6" data-anim data-anim-delay="0.08">
        <h3 class="text-xl font-semibold text-slate-900">Επιχειρησιακό αποτέλεσμα</h3>
        <div class="mt-4 space-y-3">
          <p class="panel p-4 text-sm text-slate-600">Μικρότερος χρόνος από συμβάν σε απόφαση.</p>
          <p class="panel p-4 text-sm text-slate-600">Συνεπείς καταγραφές με ελάχιστο διοικητικό φόρτο.</p>
          <p class="panel p-4 text-sm text-slate-600">Συνεχής ενημέρωση γραφείου χωρίς χειροκίνητη μεταφορά.</p>
        </div>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/el/contact" class="btn-cta">Ζητήστε demo</a>
          <a href="/el/product" class="btn-ghosty">Μάθετε περισσότερα</a>
        </div>
      </article>
    </div>
  </div>
</section>