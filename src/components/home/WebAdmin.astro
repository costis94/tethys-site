---
import SectionIntro from "./ui/SectionIntro.astro";

// Δυνατότητες διοίκησης για το web περιβάλλον
const points = [
  "Πλήρης εποπτεία χρήσεων, καταγραφών και εκκρεμοτήτων",
  "Ρόλοι και δικαιώματα με καθαρό governance model",
  "Ενιαίο ιστορικό ενεργειών για audit και διαφάνεια",
  "Εξαγωγές/αναφορές για τεκμηριωμένες αποφάσεις",
];
---

<section class="section section-border">
  <div class="container-page">
    <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
      <SectionIntro
        kicker="Web πλατφόρμα"
        title="Η διοίκηση αποκτά καθαρό έλεγχο της λειτουργίας σε ένα dashboard."
        description="Ολες οι κρίσιμες πληροφορίες συγκεντρώνονται με κοινή γλώσσα μεταξύ γραφείου και πεδίου."
      />

      <div class="space-y-3" data-anim data-anim-delay="0.08">
        {points.map((point, i) => (
          <article class="panel flex items-start gap-3 p-4 text-sm leading-6 text-slate-700" data-anim data-anim-delay={String(0.03 * (i + 1))}>
            <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-full bg-sky-600"></span>
            <span>{point}</span>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>