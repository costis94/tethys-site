---
import SectionIntro from "./ui/SectionIntro.astro";

const categories = [
  {
    label: "Μητρώα & Αρδεύσεις",
    points: [
      "Αγροτεμάχια (ΚΑΕΚ) με γεω-δεδομένα, ιστορικό και απογραφή δέντρων",
      "Μητρώο μελών με εισαγωγή CSV και συγχώνευση διπλοεγγραφών",
      "Ιστορικό αρδεύσεων ανά αγροτεμάχιο, σεζόν και καλλιέργεια",
    ],
  },
  {
    label: "Οικονομική Διαχείριση",
    points: [
      "Τιμολόγηση μελών, λογαριασμός ανά μέλος και εισπράξεις ΔΟΥ",
      "Κατηγοριοποιημένα έξοδα, προμηθευτές και παρακολούθηση πληρωμών",
      "Αναλυτικές χρηματοοικονομικές αναφορές και εξαγωγές PDF",
    ],
  },
  {
    label: "Υποθέσεις & Έλεγχος",
    points: [
      "Υποθέσεις πολλαπλών σταδίων με διαχείριση εγγράφων",
      "Πρωτόκολλα με αυτόματη αρίθμηση και διαχείριση ενστάσεων",
      "Πλήρες audit log — κάθε ενέργεια καταγεγραμμένη με χρονική σήμανση",
    ],
  },
];
---

<section class="section section-border">
  <div class="container-page">
    <SectionIntro
      kicker="Web Πλατφόρμα"
      title="Πλήρης έλεγχος της λειτουργίας από ένα περιβάλλον."
      description="Έξι ρόλοι χρηστών, εξαγωγές σε PDF/CSV/Word και διαδραστικός χάρτης GIS — όλα ενσωματωμένα."
    />

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {categories.map((cat, ci) => (
        <article class="card-soft p-6" data-anim data-anim-delay={String(0.06 * (ci + 1))}>
          <h3 class="text-base font-semibold text-slate-900">{cat.label}</h3>
          <ul class="mt-4 space-y-3">
            {cat.points.map((point) => (
              <li class="flex items-start gap-2.5 text-sm leading-6 text-slate-600">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-sky-600"></span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="mt-6 flex flex-wrap justify-center gap-3" data-anim>
      <a href="/el/product" class="btn-cta">Δείτε όλες τις δυνατότητες</a>
      <a href="/el/contact" class="btn-ghosty">Ζητήστε παρουσίαση</a>
    </div>
  </div>
</section>