---
import SectionIntro from "./ui/SectionIntro.astro";

const modules = [
  {
    category: "Μητρώο",
    title: "Αγροτεμάχια (ΚΑΕΚ)",
    body: "Γεω-δεδομένα, ιστορικό αλλαγών με αιτιολόγηση, απογραφή δέντρων και εξαγωγή PDF.",
    icon: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  },
  {
    category: "Μητρώο",
    title: "Μητρώο Μελών",
    body: "Πλήρες μητρώο με αναζήτηση, εισαγωγή CSV, συγχώνευση διπλοεγγραφών και εξαγωγές.",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  },
  {
    category: "Πεδίο",
    title: "Καταγραφές Αρδεύσεων",
    body: "Ιστορικό επισκέψεων ανά αγροτεμάχιο με επιλογή καλλιέργειας, φίλτρα σεζόν και εξαγωγή σε CSV.",
    icon: `<path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/>`,
  },
  {
    category: "Οικονομικά",
    title: "Τιμολόγηση & Εισπράξεις",
    body: "Ετήσιες χρεώσεις μελών, λογαριασμός ανά μέλος, εισπράξεις ΔΟΥ και αναλυτικές αναφορές.",
    icon: `<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>`,
  },
  {
    category: "Οικονομικά",
    title: "Έξοδα & Έσοδα",
    body: "Κατηγοριοποιημένα έξοδα, διαχείριση προμηθευτών, πληρωμές και χρηματοοικονομικές κινήσεις.",
    icon: `<line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
  },
  {
    category: "Χάρτης",
    title: "Διαδραστικός Χάρτης GIS",
    body: "Εποπτεία αγροτεμαχίων και δικτύου άρδευσης σε χάρτη. Διαθέσιμος και στο Android offline.",
    icon: `<polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/>`,
  },
  {
    category: "Διαχείριση",
    title: "Υποθέσεις & Πρωτόκολλα",
    body: "Υποθέσεις πολλαπλών σταδίων με διαχείριση αρχείων, πρωτόκολλα με αρίθμηση και ενστάσεις.",
    icon: `<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>`,
  },
  {
    category: "Υποδομή",
    title: "Αντλιοστάσια",
    body: "Παρακολούθηση κατάστασης αντλιών σε πραγματικό χρόνο με ιστορικό γεγονότων και runtime.",
    icon: `<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>`,
  },
];
---

<section class="section section-border section-alt">
  <div class="container-page">
    <SectionIntro
      kicker="Πλήρες εύρος λειτουργιών"
      title="Ένα σύστημα που καλύπτει ολόκληρη τη λειτουργία ενός ΤΟΕΒ."
      description="Από την καταγραφή ποτίσματος στο πεδίο μέχρι την τιμολόγηση μελών και τη διαχείριση αντλιοστασίων."
    />

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {modules.map((item, i) => (
        <article class="feature-card" data-anim data-anim-delay={String(0.04 * (i + 1))}>
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
          </div>
          <p class="feature-category">{item.category}</p>
          <h3 class="feature-title">{item.title}</h3>
          <p class="feature-body">{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-card {
    background: #ffffff;
    border: 1px solid var(--tethys-line);
    border-radius: 20px;
    padding: 1.75rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .feature-card:hover {
    box-shadow: 0 16px 40px rgba(0, 30, 65, 0.1);
    transform: translateY(-3px);
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--tethys-accent) 11%, white),
      color-mix(in srgb, var(--tethys-accent) 5%, white)
    );
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tethys-accent);
  }

  .feature-category {
    margin-top: 1.25rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #94a3b8;
  }

  .feature-title {
    margin-top: 0.35rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: #0d1b2a;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .feature-body {
    margin-top: 0.6rem;
    font-size: 0.85rem;
    line-height: 1.65;
    color: #64748b;
  }
</style>
