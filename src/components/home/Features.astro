---
import SectionIntro from "./ui/SectionIntro.astro";

// Οι 3 πυλώνες του προϊόντος σε executive summary μορφή
const pillars = [
  {
    title: "Android για πεδίο",
    body: "Καταγραφές, αναφορές και συμβάντα σε πραγματικές συνθήκες λειτουργίας.",
    chip: "FIELD OPS",
  },
  {
    title: "Web για διοίκηση",
    body: "Εποπτεία, ρόλοι, dashboards και συντονισμός από ένα περιβάλλον.",
    chip: "ADMIN",
  },
  {
    title: "Traceability by design",
    body: "Ολες οι σημαντικές ενέργειες μένουν τεκμηριωμένες και μετρήσιμες.",
    chip: "AUDIT",
  },
];
---

<section class="section section-border">
  <div class="container-page">
    <SectionIntro
      kicker="Τι είναι το Tethys"
      title="Ένα ενιαίο λειτουργικό σύστημα για άρδευση και επιχειρησιακό έλεγχο."
      description="Συνδέει πεδίο και γραφείο σε κοινή βάση δεδομένων, ώστε οι αποφάσεις να στηρίζονται σε πραγματική εικόνα."
    />

    <div class="mt-10 grid gap-4 lg:grid-cols-3">
      {pillars.map((item, i) => (
        <article class="card-soft p-6" data-anim data-anim-delay={String(0.06 * (i + 1))}>
          <span class="badge-soft">{item.chip}</span>
          <h3 class="mt-4 text-xl font-semibold text-slate-900">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600">{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>