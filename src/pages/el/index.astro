---
import Layout from "../../components/Layout.astro";

import Hero from "../../components/home/Hero.astro";
import Marquee from "../../components/home/Marquee.astro";
import Problem from "../../components/home/Problem.astro";
import Features from "../../components/home/Features.astro";
import OfflineField from "../../components/home/OfflineField.astro";
import WebAdmin from "../../components/home/WebAdmin.astro";
import FAQ from "../../components/home/FAQ.astro";
import CTA from "../../components/home/CTA.astro";
---

<Layout
  title="Tethys — Ψηφιακή διαχείριση άρδευσης (Εκτός σύνδεσης)"
  description="Πλατφόρμα εκτός σύνδεσης για ΤΟΕΒ: Android εφαρμογή για καταγραφές στο πεδίο + Web διαχείριση για πλήρη έλεγχο."
  lang="el"
>
  <Hero />
  <Marquee />
  <Problem />
  <Features />
  <OfflineField />
  <WebAdmin />
  <FAQ />
  <CTA />

  <script type="module">
    import { animate, inView } from "motion";

    const els = document.querySelectorAll("[data-anim]");
    els.forEach((el) => {
      const delay = Number(el.getAttribute("data-anim-delay") || "0");
      inView(
        el,
        () => {
          animate(
            el,
            {
              opacity: [0, 1],
              transform: ["translateY(14px)", "translateY(0px)"],
            },
            {
              duration: 0.55,
              easing: "cubic-bezier(0.22, 1, 0.36, 1)",
              delay,
            },
          );
        },
        { margin: "-10% 0px -10% 0px" },
      );
    });
  </script>
</Layout>
