---
import Layout from "../../components/Layout.astro";
import PageIntro from "../../components/marketing/PageIntro.astro";

const controls = [
  "Role-based πρόσβαση με σαφή δικαιώματα ανά χρήστη",
  "Καταγραφή ενεργειών με χρονική σήμανση και ιστορικό",
  "Ασφαλής μεταφορά δεδομένων και ελεγχόμενες ροές",
  "Δομημένη οργάνωση αρχείων και τεκμηρίωσης",
];
---

<Layout
  title="Ασφάλεια — Tethys"
  description="Το Tethys εφαρμόζει πρακτικές ασφαλείας και λογοδοσίας για λειτουργία ΤΟΕΒ."
  lang="el"
>
  <PageIntro
    eyebrow="Ασφάλεια"
    title="Η ασφάλεια είναι μέρος της λειτουργίας, όχι πρόσθετο χαρακτηριστικό"
    description="Σχεδιάζουμε τη ροή δεδομένων ώστε η πρόσβαση, η ιχνηλασιμότητα και η λογοδοσία να είναι ενσωματωμένες από την αρχή."
  />

  <section class="container-page section-sm">
    <div class="mx-auto max-w-4xl space-y-3">
      {controls.map((line, i) => (
        <div class="panel flex items-start gap-3 p-4 text-sm leading-6 text-slate-700" data-anim data-anim-delay={String(0.04 * (i + 1))}>
          <span class="mt-2 h-2.5 w-2.5 rounded-full bg-sky-600"></span>
          <span>{line}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="container-page section-sm">
    <div class="card-soft p-8 text-center sm:p-10" data-anim>
      <h2 class="text-2xl font-semibold text-slate-900">Χρειάζεστε περισσότερες τεχνικές λεπτομέρειες;</h2>
      <p class="mt-3 text-slate-600">Μπορούμε να μοιραστούμε αναλυτική παρουσίαση ασφάλειας για το περιβάλλον σας.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/el/contact" class="btn-cta">Επικοινωνία</a>
        <a href="/el/legal/privacy" class="btn-ghosty">Πολιτική απορρήτου</a>
      </div>
    </div>
  </section>
</Layout>