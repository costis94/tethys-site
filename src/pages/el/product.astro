---
import Layout from "../../components/Layout.astro";
import PageIntro from "../../components/marketing/PageIntro.astro";

const badgeClass: Record<string, string> = {
  "ΜΗΤΡΩΟ":    "badge-registry",
  "ΠΕΔΙΟ":     "badge-field",
  "ΟΙΚΟΝΟΜΙΚΑ":"badge-money",
  "ΧΑΡΤΗΣ":    "badge-map",
  "ΔΙΑΧΕΙΡΙΣΗ":"badge-admin",
  "ΥΠΟΔΟΜΗ":   "badge-infra",
  "ΕΛΕΓΧΟΣ":   "badge-audit",
};

const androidFeatures = [
  { title: "Offline χάρτης", body: "MapLibre με πλήρες bundle αγροτεμαχίων και δικτύου — λειτουργεί χωρίς internet." },
  { title: "Καταγραφή αρδεύσεων", body: "Επιλογή καλλιέργειας, ποικιλίας, πυκνότητας και κατάστασης ποτίσματος με GPS." },
  { title: "Αναφορές πεδίου", body: "Παραβάσεις, συμβάντα ή ενημερώσεις με έως 5 φωτογραφίες και ακριβή θέση GPS." },
  { title: "Background sync", body: "Το σύστημα εξασφαλίζει ότι τα δεδομένα ανεβαίνουν αυτόματα — χωρίς χειροκίνητη παρέμβαση." },
  { title: "Push notifications", body: "Ειδοποιήσεις για νέες αναφορές, ενημερώσεις και κατάσταση συγχρονισμού." },
  { title: "Dashboard", body: "Άμεση εικόνα ημερήσιων καταγραφών, συνολικών αναφορών και κατάστασης σύνδεσης." },
];

const webModules = [
  {
    chip: "ΜΗΤΡΩΟ",
    title: "Αγροτεμάχια (ΚΑΕΚ)",
    body: "Πλήρης διαχείριση με γεω-δεδομένα, εμβαδά, καλλιέργειες, ιστορικό αλλαγών με αιτιολόγηση, απογραφή δέντρων και εξαγωγή PDF.",
  },
  {
    chip: "ΜΗΤΡΩΟ",
    title: "Μητρώο Μελών",
    body: "Δημιουργία, ενημέρωση, αναζήτηση. Εισαγωγή μαζικά από CSV, συγχώνευση διπλοεγγραφών, εξαγωγές PDF.",
  },
  {
    chip: "ΠΕΔΙΟ",
    title: "Καταγραφές Αρδεύσεων",
    body: "Ιστορικό επισκέψεων ανά αγροτεμάχιο με φίλτρα σεζόν, κατάσταση άρδευσης, καλλιέργεια και επικύρωση θέσης GPS.",
  },
  {
    chip: "ΧΑΡΤΗΣ",
    title: "Διαδραστικός Χάρτης GIS",
    body: "Εποπτεία αγροτεμαχίων και δικτύου άρδευσης σε χάρτη. Επιλογή και διαχείριση αγροτεμαχίου απευθείας από τον χάρτη.",
  },
  {
    chip: "ΟΙΚΟΝΟΜΙΚΑ",
    title: "Τιμολόγηση Μελών",
    body: "Ετήσιες χρεώσεις, ανάλυση κόστους ανά αγροτεμάχιο, λογαριασμός ανά μέλος, αναστροφές και εξαγωγές PDF.",
  },
  {
    chip: "ΟΙΚΟΝΟΜΙΚΑ",
    title: "Εισπράξεις & ΔΟΥ",
    body: "Εισπράξεις μελών, διαχείριση οφειλών ΔΟΥ, βεβαιώσεις χρεών και παρακολούθηση χρηματοοικονομικών κινήσεων.",
  },
  {
    chip: "ΟΙΚΟΝΟΜΙΚΑ",
    title: "Έξοδα & Προμηθευτές",
    body: "Κατηγοριοποιημένα έξοδα, διαχείριση προμηθευτών με ιστορικό συναλλαγών, πληρωμές και αναλυτικές αναφορές.",
  },
  {
    chip: "ΔΙΑΧΕΙΡΙΣΗ",
    title: "Υποθέσεις & Πρωτόκολλα",
    body: "Υποθέσεις πολλαπλών σταδίων με διαχείριση αρχείων. Πρωτόκολλα με αυτόματη αρίθμηση και σύνδεση με υποθέσεις.",
  },
  {
    chip: "ΔΙΑΧΕΙΡΙΣΗ",
    title: "Αναφορές Πεδίου",
    body: "Προβολή, φιλτράρισμα και εξαγωγή αναφορών που δημιουργήθηκαν από την Android εφαρμογή. Εξαγωγή σε PDF και Word.",
  },
  {
    chip: "ΔΙΑΧΕΙΡΙΣΗ",
    title: "Ενστάσεις",
    body: "Διαχείριση ενστάσεων μελών (χρέωση, εμβαδό, στοιχεία) με προτεραιότητα, status workflow και διαχείριση εγγράφων.",
  },
  {
    chip: "ΥΠΟΔΟΜΗ",
    title: "Αντλιοστάσια",
    body: "Παρακολούθηση κατάστασης αντλιών (λειτουργία, αναμονή, βλάβη) σε πραγματικό χρόνο με ιστορικό γεγονότων.",
  },
  {
    chip: "ΕΛΕΓΧΟΣ",
    title: "Audit Log & Ρόλοι",
    body: "Πλήρες ιστορικό ενεργειών χρηστών με χρονική σήμανση. Έξι ρόλοι (Υδρονόμος, Λογιστής, Admin κ.α.) με διακριτά δικαιώματα.",
  },
];
---

<Layout
  title="Προϊόν — Tethys"
  description="Πλήρης πλατφόρμα για ΤΟΕΒ: Android εκτός σύνδεσης για το πεδίο και ολοκληρωμένο Web σύστημα για τη διοίκηση."
  lang="el"
>
  <PageIntro
    eyebrow="Προϊόν"
    title="Πλήρης πλατφόρμα για κάθε πτυχή λειτουργίας ενός ΤΟΕΒ"
    description="Android για τον υδρονόμο στο πεδίο. Web για τη διοίκηση, τα οικονομικά και τις υποθέσεις. Ένα σύστημα, μία κοινή βάση δεδομένων."
  />

  <!-- Android Section -->
  <section class="container-page section-sm">
    <div class="mb-8">
      <span class="kicker">Tethys Android</span>
      <h2 class="mt-3 text-2xl font-semibold text-slate-900 sm:text-3xl">
        Το εργαλείο του υδρονόμου — σχεδιασμένο για το πεδίο.
      </h2>
      <p class="mt-3 max-w-2xl text-slate-600">
        Λειτουργεί πλήρως εκτός σύνδεσης με offline χάρτη, καταγραφές αρδεύσεων και αναφορές με φωτογραφίες. Όταν αποκατασταθεί σύνδεση, τα δεδομένα συγχρονίζονται αυτόματα στο background.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {androidFeatures.map((item, i) => (
        <article class="card-soft p-5" data-anim data-anim-delay={String(0.04 * (i + 1))}>
          <h3 class="text-base font-semibold text-slate-900">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{item.body}</p>
        </article>
      ))}
    </div>

    <div class="mt-6 flex flex-wrap gap-3">
      <a href="/el/contact" class="btn-cta">Ζητήστε παρουσίαση</a>
    </div>
  </section>

  <!-- Web Modules Section -->
  <section class="container-page section-sm">
    <div class="mb-8">
      <span class="kicker">Web Πλατφόρμα</span>
      <h2 class="mt-3 text-2xl font-semibold text-slate-900 sm:text-3xl">
        Πλήρης έλεγχος της λειτουργίας από ένα περιβάλλον.
      </h2>
      <p class="mt-3 max-w-2xl text-slate-600">
        Μητρώα, οικονομικά, υποθέσεις, αντλιοστάσια και εξαγωγές — όλα με ρόλους χρηστών και πλήρες audit trail.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {webModules.map((item, i) => (
        <article class="card-soft p-5" data-anim data-anim-delay={String(0.03 * (i + 1))}>
          <span class={`badge-soft ${badgeClass[item.chip] ?? ""}`}>{item.chip}</span>
          <h3 class="mt-3 text-base font-semibold text-slate-900">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="container-page section-sm">
    <div class="card-soft p-8 text-center sm:p-10" data-anim>
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Θέλετε παρουσίαση με τα δικά σας σενάρια;</h2>
      <p class="mx-auto mt-4 max-w-2xl text-slate-600">
        Σας δείχνουμε πώς η ροή πεδίου και η διοίκηση ενοποιούνται στην πράξη — με πραγματικά δεδομένα.
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/el/contact" class="btn-cta">Κλείστε παρουσίαση</a>
        <a href="/el/" class="btn-ghosty">Επιστροφή στην αρχική</a>
      </div>
    </div>
  </section>
</Layout>
