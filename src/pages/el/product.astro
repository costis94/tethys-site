---
import Layout from "../../components/Layout.astro";
import PageIntro from "../../components/marketing/PageIntro.astro";
import CTA from "../../components/home/CTA.astro";
import PlatformArchitecture from "../../components/product/PlatformArchitecture.astro";

const badgeClass: Record<string, string> = {
  "ΜΗΤΡΩΟ":    "badge-registry",
  "ΠΕΔΙΟ":     "badge-field",
  "ΟΙΚΟΝΟΜΙΚΑ":"badge-money",
  "ΧΑΡΤΗΣ":    "badge-map",
  "ΔΙΑΧΕΙΡΙΣΗ":"badge-admin",
  "ΥΠΟΔΟΜΗ":   "badge-infra",
  "ΕΛΕΓΧΟΣ":   "badge-audit",
};

const androidFeatures = [
  { title: "Offline χάρτης", body: "MapLibre με πλήρες bundle αγροτεμαχίων και δικτύου - λειτουργεί χωρίς internet." },
  { title: "Καταγραφή αρδεύσεων", body: "Επιλογή καλλιέργειας, ποικιλίας, πυκνότητας και κατάστασης ποτίσματος με GPS." },
  { title: "Αναφορές πεδίου", body: "Παραβάσεις, συμβάντα ή ενημερώσεις με έως 5 φωτογραφίες και ακριβή θέση GPS." },
  { title: "Background sync", body: "Το σύστημα εξασφαλίζει ότι τα δεδομένα ανεβαίνουν αυτόματα - χωρίς χειροκίνητη παρέμβαση." },
  { title: "Push notifications", body: "Ειδοποιήσεις για νέες αναφορές, ενημερώσεις και κατάσταση συγχρονισμού." },
  { title: "Dashboard", body: "Άμεση εικόνα ημερήσιων καταγραφών, συνολικών αναφορών και κατάστασης σύνδεσης." },
];

const androidMindmapGroups = [
  {
    title: "Πεδίο",
    lead: "Η καθημερινή δραστηριότητα πεδίου καταχωρείται επιτόπου, με οργανωμένη ροή προς τη διοίκηση.",
    items: ["Καταχώριση αρδεύσεων", "Αναφορές πεδίου"],
  },
  {
    title: "Λειτουργία Εκτός Σύνδεσης",
    lead: "Η εφαρμογή λειτουργεί εκτός σύνδεσης και συγχρονίζει αυτόματα τα δεδομένα μόλις αποκατασταθεί η πρόσβαση.",
    items: ["Χάρτης εκτός σύνδεσης", "Αυτόματος συγχρονισμός"],
  },
  {
    title: "Ενημέρωση",
    lead: "Παρέχει άμεση επιχειρησιακή εικόνα με ειδοποιήσεις και συγκεντρωτικά στοιχεία.",
    items: ["Ειδοποιήσεις συμβάντων", "Ημερήσια σύνοψη"],
  },
];

const androidMindmapLeft = androidMindmapGroups.filter((_, i) => i % 2 === 0);
const androidMindmapRight = androidMindmapGroups.filter((_, i) => i % 2 === 1);

const webModules = [
  {
    chip: "ΜΗΤΡΩΟ",
    title: "Αγροτεμάχια (ΚΑΕΚ)",
    body: "Πλήρης διαχείριση με γεω-δεδομένα, εμβαδά, καλλιέργειες, ιστορικό αλλαγών με αιτιολόγηση, απογραφή δέντρων και εξαγωγή PDF.",
  },
  {
    chip: "ΜΗΤΡΩΟ",
    title: "Μητρώο Μελών",
    body: "Δημιουργία, ενημέρωση, αναζήτηση. Εισαγωγή μαζικά από CSV, συγχώνευση διπλοεγγραφών, εξαγωγές PDF.",
  },
  {
    chip: "ΠΕΔΙΟ",
    title: "Καταγραφές Αρδεύσεων",
    body: "Ιστορικό επισκέψεων ανά αγροτεμάχιο με φίλτρα σεζόν, κατάσταση άρδευσης, καλλιέργεια και επικύρωση θέσης GPS.",
  },
  {
    chip: "ΧΑΡΤΗΣ",
    title: "Διαδραστικός Χάρτης GIS",
    body: "Εποπτεία αγροτεμαχίων και δικτύου άρδευσης σε χάρτη. Επιλογή και διαχείριση αγροτεμαχίου απευθείας από τον χάρτη.",
  },
  {
    chip: "ΟΙΚΟΝΟΜΙΚΑ",
    title: "Τιμολόγηση Μελών",
    body: "Ετήσιες χρεώσεις, ανάλυση κόστους ανά αγροτεμάχιο, λογαριασμός ανά μέλος, αναστροφές και εξαγωγές PDF.",
  },
  {
    chip: "ΟΙΚΟΝΟΜΙΚΑ",
    title: "Εισπράξεις & ΔΟΥ",
    body: "Εισπράξεις μελών, διαχείριση οφειλών ΔΟΥ, βεβαιώσεις χρεών και παρακολούθηση χρηματοοικονομικών κινήσεων.",
  },
  {
    chip: "ΟΙΚΟΝΟΜΙΚΑ",
    title: "Έξοδα & Προμηθευτές",
    body: "Κατηγοριοποιημένα έξοδα, διαχείριση προμηθευτών με ιστορικό συναλλαγών, πληρωμές και αναλυτικές αναφορές.",
  },
  {
    chip: "ΔΙΑΧΕΙΡΙΣΗ",
    title: "Υποθέσεις & Πρωτόκολλα",
    body: "Υποθέσεις πολλαπλών σταδίων με διαχείριση αρχείων. Πρωτόκολλα με αυτόματη αρίθμηση και σύνδεση με υποθέσεις.",
  },
  {
    chip: "ΔΙΑΧΕΙΡΙΣΗ",
    title: "Αναφορές Πεδίου",
    body: "Προβολή, φιλτράρισμα και εξαγωγή αναφορών που δημιουργήθηκαν από την Android εφαρμογή. Εξαγωγή σε PDF και Word.",
  },
  {
    chip: "ΔΙΑΧΕΙΡΙΣΗ",
    title: "Ενστάσεις",
    body: "Διαχείριση ενστάσεων μελών (χρέωση, εμβαδό, στοιχεία) με προτεραιότητα, status workflow και διαχείριση εγγράφων.",
  },
  {
    chip: "ΥΠΟΔΟΜΗ",
    title: "Αντλιοστάσια",
    body: "Παρακολούθηση κατάστασης αντλιών (λειτουργία, αναμονή, βλάβη) σε πραγματικό χρόνο με ιστορικό γεγονότων.",
  },
  {
    chip: "ΕΛΕΓΧΟΣ",
    title: "Audit Log & Ρόλοι",
    body: "Πλήρες ιστορικό ενεργειών χρηστών με χρονική σήμανση. Έξι ρόλοι (Υδρονόμος, Λογιστής, Admin κ.α.) με διακριτά δικαιώματα.",
  },
];

const webSectionOrder = ["ΜΗΤΡΩΟ", "ΠΕΔΙΟ", "ΟΙΚΟΝΟΜΙΚΑ", "ΔΙΑΧΕΙΡΙΣΗ", "ΥΠΟΔΟΜΗ", "ΕΛΕΓΧΟΣ", "ΧΑΡΤΗΣ"] as const;

const webSectionMeta: Record<string, { title: string; lead: string }> = {
  "ΜΗΤΡΩΟ": { title: "Μητρώα", lead: "Βάση δεδομένων οργανωμένη και ενιαία." },
  "ΠΕΔΙΟ": { title: "Πεδίο", lead: "Ροή πληροφοριών από τον υδρονόμο στη διοίκηση." },
  "ΟΙΚΟΝΟΜΙΚΑ": { title: "Οικονομικά", lead: "Τιμολόγηση, εισπράξεις και πλήρης οικονομική εικόνα." },
  "ΔΙΑΧΕΙΡΙΣΗ": { title: "Διαχείριση", lead: "Υποθέσεις, πρωτόκολλα και διαδικασίες χωρίς χαρτί." },
  "ΥΠΟΔΟΜΗ": { title: "Υποδομή", lead: "Εποπτεία κρίσιμων εγκαταστάσεων σε πραγματικό χρόνο." },
  "ΕΛΕΓΧΟΣ": { title: "Έλεγχος", lead: "Ιχνηλασιμότητα ενεργειών και σαφή δικαιώματα πρόσβασης." },
  "ΧΑΡΤΗΣ": { title: "Γεωχωρικά", lead: "Χαρτογραφική αποτύπωση για άμεσες αποφάσεις." },
};

const webModulesGrouped = webSectionOrder
  .map((chip) => ({
    chip,
    meta: webSectionMeta[chip],
    items: webModules.filter((module) => module.chip === chip),
  }))
  .filter((group) => group.items.length > 0);

const webMindmapLeft = webModulesGrouped.filter((_, i) => i % 2 === 0);
const webMindmapRight = webModulesGrouped.filter((_, i) => i % 2 === 1);
---

<Layout
  title="Προϊόν — Tethys"
  description="Πλήρης πλατφόρμα για ΤΟΕΒ: Android εκτός σύνδεσης για το πεδίο και ολοκληρωμένο Web σύστημα για τη διοίκηση."
  lang="el"
>
  <div class="product-page">
    <div id="product-scroll-progress" class="product-scroll-progress" aria-hidden="true"></div>
    <div class="product-hero" data-product-hero>
      <div class="product-hero-bg" aria-hidden="true">
        <div id="product-blob-1" class="product-blob product-blob-left"></div>
        <div id="product-blob-2" class="product-blob product-blob-right"></div>
      </div>

  <PageIntro
    title="Πλήρης πλατφόρμα για κάθε πτυχή λειτουργίας ενός ΤΟΕΒ"
    description="Android για τον υδρονόμο στο πεδίο. Web για τη διοίκηση, τα οικονομικά και τις υποθέσεις. Ένα σύστημα, μία κοινή βάση δεδομένων."
  />

    </div>

  <!-- Android Section -->
  <section class="container-page section-sm">
    <div class="mb-8">
      <span class="kicker">Tethys Android</span>
      <h2 class="mt-3 text-2xl font-semibold text-slate-900 sm:text-3xl">
        Το εργαλείο του υδρονόμου — σχεδιασμένο για το πεδίο.
      </h2>
      <p class="mt-3 max-w-2xl text-slate-600">
        Λειτουργεί πλήρως εκτός σύνδεσης με offline χάρτη, καταγραφές αρδεύσεων και αναφορές με φωτογραφίες. Όταν αποκατασταθεί σύνδεση, τα δεδομένα συγχρονίζονται αυτόματα στο background.
      </p>
    </div>
    <div class="mindmap-shell mindmap-shell-android card-soft p-5 sm:p-8" data-anim>
      <div class="mindmap-center-wrap">
        <article class="mindmap-center">
          <span class="mindmap-kicker">Εφαρμογή Android</span>
          <h3 class="mt-2 text-lg font-semibold text-slate-900">Εργαλείο πεδίου για καθημερινή λειτουργία</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Καταγραφή εργασιών πεδίου, λειτουργία εκτός σύνδεσης και αυτόματη ενοποίηση δεδομένων με τη web πλατφόρμα.
          </p>
        </article>
      </div>

      <div class="mindmap-grid">
        <div class="mindmap-col">
          {androidMindmapLeft.map((group, i) => (
            <article class={`mindmap-node ${group.title === "Λειτουργία Εκτός Σύνδεσης" ? "mindmap-node-compact" : ""}`} data-anim data-anim-delay={String(0.03 * (i + 1))}>
              <div class="mindmap-node-head">
                <h4 class="mindmap-node-title">{group.title}</h4>
              </div>
              <p class="mindmap-node-lead">{group.lead}</p>
              <ul class="mindmap-list">
                {group.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>

        <div class="mindmap-col">
          {androidMindmapRight.map((group, i) => (
            <article class={`mindmap-node ${group.title === "Λειτουργία Εκτός Σύνδεσης" ? "mindmap-node-compact" : ""}`} data-anim data-anim-delay={String(0.03 * (i + 1))}>
              <div class="mindmap-node-head">
                <h4 class="mindmap-node-title">{group.title}</h4>
              </div>
              <p class="mindmap-node-lead">{group.lead}</p>
              <ul class="mindmap-list">
                {group.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
  <!-- Web Modules Section -->
  <section class="container-page section-sm">
    <div class="mb-8">
      <span class="kicker">Web Πλατφόρμα</span>
      <h2 class="mt-3 text-2xl font-semibold text-slate-900 sm:text-3xl">
        Πλήρης έλεγχος της λειτουργίας από ένα περιβάλλον.
      </h2>
      <p class="mt-3 max-w-2xl text-slate-600">
        Μητρώα, οικονομικά, υποθέσεις, αντλιοστάσια και εξαγωγές - όλα με ρόλους χρηστών και πλήρες audit trail.
      </p>
    </div>

    <div class="mindmap-shell card-soft p-5 sm:p-8" data-anim>
      <div class="mindmap-center-wrap">
        <article class="mindmap-center">
          <span class="mindmap-kicker">Web Platform</span>
          <h3 class="mt-2 text-lg font-semibold text-slate-900">Κεντρικό περιβάλλον διοίκησης</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Όλα τα δεδομένα του ΤΟΕΒ συγκεντρωμένα σε ενιαία εικόνα με ρόλους, ιστορικό και πλήρη έλεγχο ροών.
          </p>
        </article>
      </div>

      <div class="mindmap-grid">
        <div class="mindmap-col">
          {webMindmapLeft.map((group, gi) => (
            <article class="mindmap-node" data-anim data-anim-delay={String(0.03 * (gi + 1))}>
              <div class="mindmap-node-head">
                <h4 class="mindmap-node-title">{group.meta.title}</h4>
                <span class={`badge-soft ${badgeClass[group.chip] ?? ""}`}>{group.chip}</span>
              </div>
              <p class="mindmap-node-lead">{group.meta.lead}</p>
              <ul class="mindmap-list">
                {group.items.map((item) => (
                  <li>{item.title}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>

        <div class="mindmap-col">
          {webMindmapRight.map((group, gi) => (
            <article class="mindmap-node" data-anim data-anim-delay={String(0.03 * (gi + 1))}>
              <div class="mindmap-node-head">
                <h4 class="mindmap-node-title">{group.meta.title}</h4>
                <span class={`badge-soft ${badgeClass[group.chip] ?? ""}`}>{group.chip}</span>
              </div>
              <p class="mindmap-node-lead">{group.meta.lead}</p>
              <ul class="mindmap-list">
                {group.items.map((item) => (
                  <li>{item.title}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <PlatformArchitecture />
  <CTA />
  </div>
</Layout>

<style>
  .mindmap-shell {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(120% 120% at 50% -10%, rgba(0, 54, 107, 0.08), transparent 45%),
      #fff;
  }

  .mindmap-shell-android {
    background:
      radial-gradient(120% 120% at 50% -10%, rgba(24, 165, 141, 0.1), transparent 45%),
      #fff;
  }

  .mindmap-center-wrap {
    position: relative;
    display: flex;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .mindmap-center-wrap::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -16px;
    width: 2px;
    height: 18px;
    transform: translateX(-50%);
    background: #cbd5e1;
  }

  .mindmap-center {
    width: min(100%, 560px);
    border: 1px solid #d7e1eb;
    border-radius: 18px;
    padding: 1rem 1.1rem;
    background: linear-gradient(180deg, #ffffff, #f8fbff);
    box-shadow: 0 10px 26px rgba(15, 35, 60, 0.08);
    text-align: center;
  }

  .mindmap-kicker {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #00366b;
    background: rgba(0, 54, 107, 0.1);
  }

  .mindmap-grid {
    position: relative;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  .mindmap-col {
    display: grid;
    gap: 0.9rem;
  }

  .mindmap-node {
    position: relative;
    border: 1px solid #dde6ef;
    border-radius: 16px;
    background: #fff;
    padding: 0.9rem 0.95rem;
  }

  .mindmap-node-compact {
    align-self: start;
    max-width: 92%;
    padding: 0.68rem 0.78rem;
  }

  .mindmap-node-compact .mindmap-node-lead {
    margin-top: 0.2rem;
    font-size: 0.76rem;
    line-height: 1.38;
  }

  .mindmap-node-compact .mindmap-list {
    margin-top: 0.38rem;
    gap: 0.1rem;
    font-size: 0.78rem;
  }

  .mindmap-node-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.7rem;
  }

  .mindmap-node-title {
    font-size: 1rem;
    line-height: 1.3;
    font-weight: 700;
    color: #0f172a;
  }

  .mindmap-node-lead {
    margin-top: 0.35rem;
    font-size: 0.83rem;
    line-height: 1.5;
    color: #5b6b80;
  }

  .mindmap-list {
    margin-top: 0.55rem;
    padding-left: 1rem;
    display: grid;
    gap: 0.2rem;
    color: #334155;
    font-size: 0.84rem;
    line-height: 1.45;
  }

  @media (min-width: 1024px) {
    .mindmap-grid {
      grid-template-columns: 1fr 1fr;
      column-gap: 1.3rem;
    }

    .mindmap-grid::before {
      content: "";
      position: absolute;
      left: 50%;
      top: -10px;
      bottom: 0;
      width: 2px;
      transform: translateX(-50%);
      background: #d5dfeb;
    }

    .mindmap-node::before {
      content: "";
      position: absolute;
      top: 22px;
      width: 14px;
      height: 2px;
      background: #d5dfeb;
    }

    .mindmap-col:first-child .mindmap-node::before {
      right: -14px;
    }

    .mindmap-col:last-child .mindmap-node::before {
      left: -14px;
    }
  }

  .product-scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 70;
    width: 100%;
    height: 3px;
    transform: scaleX(0);
    transform-origin: left center;
    background: linear-gradient(90deg, #00366b, #00509e, #0076c7);
    box-shadow: 0 0 12px rgba(0, 80, 158, 0.35);
    pointer-events: none;
  }

  .product-hero {
    position: relative;
    overflow: hidden;
  }

  .product-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .product-blob {
    position: absolute;
    border-radius: 999px;
    filter: blur(52px);
    opacity: 0.9;
    will-change: transform;
  }

  .product-blob-left {
    left: -4rem;
    top: -1.5rem;
    width: 17rem;
    height: 17rem;
    background: rgba(0, 54, 107, 0.14);
  }

  .product-blob-right {
    right: -3rem;
    top: 2rem;
    width: 19rem;
    height: 19rem;
    background: rgba(0, 80, 158, 0.12);
  }

  .product-hero :global(section) {
    position: relative;
    z-index: 1;
  }

  .product-hero :global(h1) {
    font-family: "Fraunces", Georgia, serif;
    font-optical-sizing: auto;
    font-variation-settings: "opsz" 72;
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: #0f172a;
  }

  .product-title-cursor {
    margin-left: 2px;
    color: #00366b;
    font-weight: 300;
    animation: product-title-cursor-blink 1.05s step-end infinite;
  }

  .product-title-muted {
    color: #64748b;
  }

  :global(.product-page .btn-cta-white) {
    position: relative;
    overflow: hidden;
  }

  :global(.product-page .btn-cta-white::before) {
    content: "";
    position: absolute;
    top: -140%;
    left: -44%;
    width: 24%;
    height: 380%;
    transform: rotate(20deg);
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(0, 118, 199, 0.2) 40%,
      rgba(255, 255, 255, 0.72) 52%,
      rgba(0, 118, 199, 0.2) 64%,
      rgba(255, 255, 255, 0) 100%
    );
    animation: product-cta-shimmer 3.1s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes product-title-cursor-blink {
    0%,
    100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @keyframes product-cta-shimmer {
    0%,
    18% {
      left: -44%;
      opacity: 0;
    }
    26% {
      opacity: 1;
    }
    46% {
      left: 132%;
      opacity: 0;
    }
    100% {
      left: 132%;
      opacity: 0;
    }
  }
</style>

<script is:inline>
  (function () {
    var prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    var progressEl = document.getElementById("product-scroll-progress");
    function updateProgress() {
      if (!progressEl) return;
      var top = window.scrollY || document.documentElement.scrollTop || 0;
      var max = document.documentElement.scrollHeight - window.innerHeight;
      var ratio = max > 0 ? Math.min(1, Math.max(0, top / max)) : 0;
      progressEl.style.transform = "scaleX(" + ratio + ")";
    }

    updateProgress();
    window.addEventListener("scroll", updateProgress, { passive: true });
    window.addEventListener("resize", updateProgress);

    if (prefersReducedMotion) return;

    var blob1 = document.getElementById("product-blob-1");
    var blob2 = document.getElementById("product-blob-2");
    if (blob1 && blob2) {
      var ticking = false;
      function paintParallax() {
        var y = window.scrollY || 0;
        blob1.style.transform = "translate3d(0," + y * 0.13 + "px,0)";
        blob2.style.transform = "translate3d(" + y * 0.05 + "px," + y * -0.1 + "px,0)";
        ticking = false;
      }
      function onScroll() {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(paintParallax);
      }
      paintParallax();
      window.addEventListener("scroll", onScroll, { passive: true });
    }

    var hero = document.querySelector("[data-product-hero]");
    var heroTitle = hero ? hero.querySelector("h1") : null;
    if (!heroTitle) return;

    var headingText = (heroTitle.textContent || "").replace(/\s+/g, " ").trim();
    if (!headingText) return;

    heroTitle.innerHTML = '<span id="product-title-typed-text"></span><span class="product-title-cursor" aria-hidden="true">|</span>';
    var target = document.getElementById("product-title-typed-text");
    if (!target) return;

    var suffix = "ενός ΤΟΕΒ";
    var splitAt = headingText.lastIndexOf(suffix);

    function escapeHtml(value) {
      return value
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
    }

    var charIdx = 0;
    function tickHeadingOnce() {
      charIdx += 1;
      if (splitAt > -1 && charIdx > splitAt) {
        var prefixText = headingText.slice(0, splitAt);
        var suffixText = headingText.slice(splitAt, charIdx);
        target.innerHTML = escapeHtml(prefixText) + '<span class="product-title-muted">' + escapeHtml(suffixText) + "</span>";
      } else {
        target.textContent = headingText.slice(0, charIdx);
      }
      if (charIdx < headingText.length) {
        setTimeout(tickHeadingOnce, 46);
        return;
      }
      var cursor = heroTitle.querySelector(".product-title-cursor");
      if (cursor) {
        cursor.style.animation = "none";
        cursor.style.opacity = "1";
      }
    }

    tickHeadingOnce();
  })();
</script>


