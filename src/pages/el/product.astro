---
import Layout from "../../components/Layout.astro";
import PageIntro from "../../components/marketing/PageIntro.astro";

const pillars = [
  {
    title: "Android στο πεδίο",
    body: "Καταγραφές άρδευσης, συμβάντα και αναφορές με offline-first λειτουργία.",
  },
  {
    title: "Web διοίκησης",
    body: "Εποπτεία λειτουργίας, αναζήτηση ιστορικού, dashboards και διαχείριση ρόλων.",
  },
  {
    title: "Ενιαίο ιστορικό",
    body: "Ολες οι κρίσιμες ενέργειες παραμένουν τεκμηριωμένες με χρονική ακολουθία.",
  },
];
---

<Layout
  title="Προϊόν — Tethys"
  description="Το Tethys ενώνει Android πεδίου και Web διοίκησης σε ενιαίο σύστημα διαχείρισης άρδευσης."
  lang="el"
>
  <PageIntro
    eyebrow="Προϊόν"
    title="Μια ενιαία πλατφόρμα για πραγματική λειτουργία ΤΟΕΒ"
    description="Το Tethys συνδέει καθημερινές καταγραφές, διοικητικό έλεγχο και επιχειρησιακή λογοδοσία σε ένα κοινό περιβάλλον."
  />

  <section class="container-page section-sm">
    <div class="grid gap-4 md:grid-cols-3">
      {pillars.map((item, i) => (
        <article class="card-soft p-6" data-anim data-anim-delay={String(0.05 * (i + 1))}>
          <h2 class="text-xl font-semibold text-slate-900">{item.title}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-600">{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-page section-sm">
    <div class="card-soft p-8 text-center sm:p-10" data-anim>
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Θέλετε live παρουσίαση με πραγματικά σενάρια;</h2>
      <p class="mx-auto mt-4 max-w-2xl text-slate-600">
        Σας δείχνουμε πώς η ροή πεδίου και η διοίκηση ενοποιούνται στην πράξη.
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/el/contact" class="btn-cta">Κλείστε παρουσίαση</a>
        <a href="/el/" class="btn-ghosty">Επιστροφή στην αρχική</a>
      </div>
    </div>
  </section>
</Layout>