---
import Layout from "../../components/Layout.astro";
---

<Layout
  title="Tethys — Offline-first irrigation operations"
  description="Unified platform for field operations and administration in irrigation organizations."
  lang="en"
>
  <section class="container-page section">
    <div class="mx-auto max-w-4xl text-center" data-anim>
      <span class="kicker">English</span>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">Modern irrigation operations, unified.</h1>
      <p class="mx-auto mt-5 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">
        Tethys connects offline Android field work with web administration into one operational system.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a class="btn-cta" href="/el/">View Greek site</a>
        <a class="btn-ghosty" href="mailto:hello@tethys.gr">Contact team</a>
      </div>
    </div>
  </section>
</Layout>